{
  "name": "centsibleapp",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "npx expo start --dev-client -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android:dev": "npx --yes eas-cli@latest build -p android --profile development --clear-cache",
    "build:android:preview": "npx --yes eas-cli@latest build -p android --profile preview --clear-cache",
    "build:android:prod": "npx --yes eas-cli@latest build -p android --profile production --clear-cache",
    "build:ios:dev": "npx --yes eas-cli@latest build -p ios --profile development --clear-cache",
    "build:ios:preview": "npx --yes eas-cli@latest build -p ios --profile preview --clear-cache",
    "build:ios:prod": "npx --yes eas-cli@latest build -p ios --profile production --clear-cache"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "~2.1.2",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/drawer": "^7.9.4",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "expo": "~55.0.5",
    "expo-auth-session": "~55.0.15",
    "expo-blur": "~55.0.14",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "~55.0.13",
    "expo-file-system": "~55.0.10",
    "expo-image-picker": "~55.0.19",
    "expo-print": "~55.0.8",
    "expo-sharing": "~55.0.11",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.14",
    "firebase": "^12.12.1",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "0.7.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.8.0"
  },
  "private": true
}
